{
	"name": "ventairy-public-api",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Ventairy API: An open-source payment orchestration for borderless commerce. Use directly from your apps, terminal, or LLMs via API keys.",
	"engines": {
		"node": ">=25.0.0",
		"bun": ">=1"
	},
	"scripts": {
		"build": "nest build && tsc-alias",
		"start": "nest start --exec bun",
		"start:dev": "nest start --watch --exec bun",
		"start:debug": "nest start --debug --watch --exec bun",
		"start:prod": "bun dist/main.js",
		"lint": "eslint \"{src,test}/**/*.ts\" --fix",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"test:e2e": "vitest run --config ./test/vitest-e2e.config.ts",
		"test:worker": "vitest run --config ./vitest-worker.config.ts",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:deploy": "bun run scripts/deploy-migrations.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1043.0",
		"@nestjs/axios": "^4.0.1",
		"@nestjs/common": "11.1.0",
		"@nestjs/config": "4.0.2",
		"@nestjs/core": "11.1.0",
		"@nestjs/event-emitter": "3.0.1",
		"@nestjs/platform-express": "11.1.0",
		"@nestjs/schedule": "6.0.0",
		"@nestjs/swagger": "11.2.0",
		"@nestjs/terminus": "11.0.0",
		"@nestjs/throttler": "6.5.0",
		"axios": "^1.16.0",
		"class-transformer": "0.5.1",
		"class-validator": "0.14.2",
		"cookie-parser": "^1.4.7",
		"drizzle-orm": "^0.45.2",
		"file-type": "^22.0.1",
		"helmet": "8.1.0",
		"joi": "17.13.3",
		"jose": "^6.2.3",
		"nestjs-cls": "6.2.0",
		"nestjs-pino": "4.2.0",
		"opossum": "8.4.0",
		"pino": "9.6.0",
		"pino-pretty": "13.0.0",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"siwe": "^3.0.0",
		"viem": "^2.48.8"
	},
	"devDependencies": {
		"@cloudflare/containers": "^0.3.3",
		"@cloudflare/workers-types": "^4.20260505.1",
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@eslint/js": "9.39.4",
		"@nestjs/cli": "11.0.7",
		"@nestjs/schematics": "11.0.5",
		"@nestjs/testing": "11.1.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "5.0.2",
		"@types/multer": "^2.1.0",
		"@types/node": "22.15.3",
		"@typescript-eslint/eslint-plugin": "8.32.0",
		"@typescript-eslint/parser": "8.32.0",
		"@vitest/coverage-v8": "3.2.1",
		"drizzle-kit": "0.31.1",
		"eslint": "9.27.0",
		"eslint-config-prettier": "10.1.5",
		"eslint-plugin-import": "2.31.0",
		"eslint-plugin-security": "3.0.1",
		"eslint-plugin-sonarjs": "1.0.4",
		"eslint-plugin-unicorn": "59.0.0",
		"gitleaks": "1.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.0.0",
		"prettier": "3.5.3",
		"supertest": "7.1.0",
		"ts-loader": "9.5.2",
		"ts-morph": "^28.0.0",
		"tsc-alias": "^1.8.17",
		"tsconfig-paths": "4.2.0",
		"typescript": "5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "3.2.1",
		"wrangler": "^4.87.0"
	}
}
