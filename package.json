{
	"name": "ventairy-api",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Cross-border payment orchestration layer — fiat in, stablecoins out",
	"scripts": {
		"build": "nest build",
		"start": "nest start --exec bun",
		"start:dev": "nest start --watch --exec bun",
		"start:debug": "nest start --debug --watch --exec bun",
		"start:prod": "bun dist/main.js",
		"lint": "eslint \"{src,test}/**/*.ts\" --fix",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"test:e2e": "vitest run --config ./test/vitest-e2e.config.ts",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"prepare": "husky"
	},
	"dependencies": {
		"@nestjs/axios": "^4.0.1",
		"@nestjs/common": "11.1.0",
		"@nestjs/config": "4.0.2",
		"@nestjs/core": "11.1.0",
		"@nestjs/event-emitter": "3.0.1",
		"@nestjs/platform-express": "11.1.0",
		"@nestjs/schedule": "6.0.0",
		"@nestjs/swagger": "11.2.0",
		"@nestjs/terminus": "11.0.0",
		"@nestjs/throttler": "6.5.0",
		"@unkey/api": "2.3.3",
		"axios": "^1.16.0",
		"class-transformer": "0.5.1",
		"class-validator": "0.14.2",
		"drizzle-orm": "0.43.1",
		"helmet": "8.1.0",
		"joi": "17.13.3",
		"nestjs-cls": "6.2.0",
		"nestjs-pino": "4.2.0",
		"opossum": "8.4.0",
		"pino": "9.6.0",
		"pino-pretty": "13.0.0",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2"
	},
	"devDependencies": {
		"@commitlint/cli": "19.8.1",
		"@commitlint/config-conventional": "19.8.1",
		"@eslint/js": "9.39.4",
		"@nestjs/cli": "11.0.7",
		"@nestjs/schematics": "11.0.5",
		"@nestjs/testing": "11.1.0",
		"@types/express": "5.0.2",
		"@types/node": "22.15.3",
		"@typescript-eslint/eslint-plugin": "8.32.0",
		"@typescript-eslint/parser": "8.32.0",
		"@vitest/coverage-v8": "3.2.1",
		"drizzle-kit": "0.31.1",
		"eslint": "9.27.0",
		"eslint-config-prettier": "10.1.5",
		"eslint-plugin-import": "2.31.0",
		"eslint-plugin-security": "3.0.1",
		"eslint-plugin-sonarjs": "1.0.4",
		"eslint-plugin-unicorn": "59.0.0",
		"gitleaks": "1.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.0.0",
		"prettier": "3.5.3",
		"supertest": "7.1.0",
		"ts-loader": "9.5.2",
		"tsconfig-paths": "4.2.0",
		"typescript": "5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "3.2.1"
	}
}
