# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000


# ── Cloudflare D1 ────────────────────────────────────────────────────────────
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_D1_API_TOKEN=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Swagger ───────────────────────────────────────────────────────────────────

# ── SIWE (Sign-In with Ethereum) ──────────────────────────────────────────────
SIWE_DOMAIN=
SIWE_URI=
SIWE_NONCE_TTL_SECONDS=

# ── Cloudflare R2 ──────────────────────────────────────────────────────────────
R2_ENDPOINT=
R2_BUSINESS_FILES_ACCESS_KEY_ID=
R2_BUSINESS_FILES_SECRET_ACCESS_KEY=
R2_BUSINESS_FILES_BUCKET_NAME=
