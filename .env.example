# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of domain suffixes to allow.
# e.g. "ventairy.com,localhost:3000" allows *.ventairy.com and *localhost:3000
CORS_ALLOWED_DOMAINS=ventairy.com,localhost:3000

# ── Cloudflare D1 ────────────────────────────────────────────────────────────
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_D1_API_TOKEN=

# ── Unkey (API Key Management) ────────────────────────────────────────────────
UNKEY_API_ID=
UNKEY_ROOT_KEY=

# ── Liquidity Providers ────────────────────────────────────────────────────────
BLINDPAY_API_KEY=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Swagger ───────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=false
